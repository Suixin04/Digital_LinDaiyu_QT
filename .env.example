# --- LLM (required) ---
DEEPSEEK_API_KEY=
CHAT_MODEL=deepseek-v4-flash
CHAT_BASE_URL=https://api.deepseek.com/v1

# --- DeepSeek agent / tool calling ---
DIGITAL_LDY_ENABLE_TOOL_CALLS=1
DIGITAL_LDY_MAX_TOOL_ROUNDS=4
DEEPSEEK_THINKING=1
DEEPSEEK_REASONING_EFFORT=high       # high / max
DIGITAL_LDY_STREAM_DELAY_MS=10

# --- Retrieval (optional) ---
DIGITAL_LDY_ENABLE_RETRIEVAL=1
EMBEDDING_BACKEND=auto                # auto / dashscope / fastembed
FASTEMBED_MODEL=BAAI/bge-small-zh-v1.5
DIGITAL_LDY_TOP_K=3
DIGITAL_LDY_REBUILD_KB=0
DIGITAL_LDY_STORE_AI_RESPONSE=0
DIGITAL_LDY_STORE_USER_MESSAGE=0

# --- DashScope (optional: cloud embedding / ASR / CosyVoice TTS) ---
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# --- TTS (optional) ---
TTS_BACKEND=gpt_sovits                # gpt_sovits / cosyvoice / none
COSYVOICE_VOICE=longxiaochun

# --- GPT-SoVITS (本地 api_v2.py) ---
GPT_SOVITS_AUTO_START=1                                                # 0 表示外部已自行启动 api_v2
GPT_SOVITS_HOST=127.0.0.1
GPT_SOVITS_PORT=9880
GPT_SOVITS_DIR=GPT-SoVITS
GPT_SOVITS_PYTHON=                                                     # 默认 GPT-SoVITS/.venv-gsv/Scripts/python.exe
GPT_SOVITS_CONFIG=GPT_SoVITS/configs/tts_infer.yaml
GPT_SOVITS_GPT_WEIGHTS=GPT_weights_v2ProPlus/LinDaiyu-e15.ckpt
GPT_SOVITS_SOVITS_WEIGHTS=SoVITS_weights_v2ProPlus/LinDaiyu_e8_s720.pth
GPT_SOVITS_REF_AUDIO=resources/samples/17.MP3
GPT_SOVITS_PROMPT_TEXT=别扫大家的兴。舅舅要是叫你，就说姨妈留你吃酒呢。
GPT_SOVITS_TEXT_LANG=zh
GPT_SOVITS_PROMPT_LANG=zh
GPT_SOVITS_FFMPEG_BIN=                                                 # 默认 GPT-SoVITS/runtime/ffmpeg/bin
GPT_SOVITS_STARTUP_TIMEOUT=60
